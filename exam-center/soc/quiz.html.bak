<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Palo Alto Networks SecOps Pro Quiz</title>
  <link rel="stylesheet" href="../styles.css">
</head>
<body>

<div class="container">
  <div class="header">
    <h1>🕵️ SOC Professional Quiz</h1>
    <div class="exam-info"><strong>Exam:</strong> Palo Alto Networks Security Operations Professional · 90 Questions</div>
  </div>

  <!-- Home Page -->
  <div id="home-page">
    <div class="card" style="text-align: center;">
      <div style="font-size: 40px; margin-bottom: 16px;">🕵️</div>
      <h2>Start Your Quiz</h2>
      <p style="color: var(--text-muted); margin-bottom: 24px;">Select number of questions and begin</p>

      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(130px, 1fr)); gap: 12px; margin-bottom: 20px;">
        <button class="btn btn-primary" onclick="startQuiz(20)">20 Questions</button>
        <button class="btn btn-primary" onclick="startQuiz(60)">60 Questions</button>
        <button class="btn btn-success" onclick="startQuiz(90)">All (90) Questions</button>
      </div>

      <div class="info-box" style="text-align: left;">
        <strong>📌 How to use:</strong>
        <ul>
          <li>Select the number of questions to begin a timed quiz</li>
          <li>Questions and options are randomized each time</li>
          <li>Single/Multi-select auto-detected</li>
          <li>Use "Show Answer" to verify your selection</li>
          <li>Click Submit to see your final score and results</li>
          <li>Pass mark: 60%</li>
        </ul>
      </div>

      <button class="btn btn-outline" onclick="showAnswerKey()" style="width: 100%; margin-bottom: 16px;">📖 答案一覽 (Answer Key)</button>

      <div class="stats-grid" style="margin-top: 20px;">
        <div class="stat-item">
          <div class="number">89</div>
          <div class="label">Total Questions</div>
        </div>
        <div class="stat-item">
          <div class="number">10</div>
          <div class="label">Points per Question</div>
        </div>
        <div class="stat-item">
          <div class="number">60%</div>
          <div class="label">Pass Mark</div>
        </div>
      </div>

      <div style="margin-top: 16px;">
        <a href="../index.html" class="btn btn-secondary">← Back to Exam Center</a>
      </div>
    </div>
  </div>

  <!-- Quiz Page -->
  <div id="quiz-page" class="hidden">
    <div class="card">
      <div class="score-bar" style="display: none;">890</span></span>
      </div>
      <div class="progress-bar">
        <div class="progress-fill" id="progress-fill" style="width: 0%"></div>
      </div>
      <div class="question-header">
        <div>
          <span class="question-number" id="q-number">1</span>
          <span id="q-total" style="color: var(--text-muted); font-size: 13px;">of 20 questions</span>
        </div>
        <span class="question-type" id="q-type">Single Select</span>
      </div>
      <div class="question-text" id="q-text">Loading question...</div>
      <button class="show-answer-btn" onclick="toggleAnswer()">👁️ Show Answer</button>
      <div class="answer-display" id="answer-display"></div>
      <div class="options" id="options-container"></div>
      <div class="nav-buttons">
        <button class="btn btn-primary" onclick="prevQuestion()" id="btn-prev" disabled>← Previous</button>
        <button class="btn btn-primary" onclick="nextQuestion()" id="btn-next">Next →</button>
        <button class="btn btn-success" onclick="submitQuiz()" id="btn-submit" style="display: none;">✓ Submit Quiz</button>
        <button class="btn btn-secondary" onclick="goHome()">⌂ Home</button>
      </div>
    </div>
  </div>

  <!-- Results Page -->
  <div id="results-page" class="hidden">
    <div class="card">
      <div class="results">
        <div class="results-score" id="final-score">0</div>
        <div class="results-message" id="result-message">Loading...</div>
        <div class="results-details">
          <div><span>Total Questions:</span> <span id="result-total">0</span></div>
          <div><span>Correct Answers:</span> <span id="result-correct">0</span></div>
          <div><span>Your Score:</span> <span id="result-score">0 / 900</span></div>
          <div><span>Pass Mark:</span> <span>60%</span></div>
          <div><span>Status:</span> <span id="result-status" style="font-weight: 700;">—</span></div>
        </div>
        <div class="review-section">
          <h3>📝 Answer Review</h3>
          <div id="review-list"></div>
        </div>
        <div class="nav-buttons" style="margin-top: 20px;">
          <button class="btn btn-secondary" onclick="goHome()">⌂ Back to Home</button>
          <button class="btn btn-warning" onclick="retakeQuiz()">🔄 Retake Quiz</button>
        </div>
      </div>
    </div>
  </div>

  <!-- Answer Key Page -->
  <div id="answer-key-page" class="hidden">
    <div class="card">
      <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px;">
        <h2 style="font-size: 20px; color: var(--primary);">📖 Answer Key — All 90 Questions</h2>
        <button class="btn btn-secondary" onclick="goHome()">← Back</button>
      </div>
      <p style="color: var(--text-muted); font-size: 13px; margin-bottom: 20px;">
        順序顯示 1-90 題，每題 choices 跟原始順序。
        <span style="background: #e8f5e9; padding: 2px 6px; border-radius: 3px; font-weight: 600;">綠色 highlight</span> = 正確答案
      </p>
      <div id="answer-key-content"></div>
    </div>
  </div>
</div>

<script src="questions.js"></script>
<script>
  const PASS_PERCENT = 70;
  const POINTS_PER_Q = 10;

  let selectedQuestions = [];
  let currentQuestion = 0;
  let userAnswers = {};
  let showAnswerState = {};

  function shuffleArray(arr) {
    const a = [...arr];
    for (let i = a.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [a[i], a[j]] = [a[j], a[i]];
    }
    return a;
  }

  // Convert questionBank format to our standard format
  function normalizeQuestion(q) {
    return {
      num: 0,
      text: q.text.replace(/<br>/g, '\n'),
      choices: q.options.map(o => ({letter: o.value, text: o.text})),
      answer: Array.isArray(q.correct) ? q.correct.join('') : q.correct,
      type: q.multi ? 'multi' : 'single'
    };
  }

  function shuffleChoices(normQ) {
    const q = {...normQ};
    // Shuffle TEXT only, keep ABCD letter labels fixed
    const texts = q.choices.map(c => c.text);
    const shuffledTexts = shuffleArray(texts);
    q.choices = q.choices.map((c, i) => ({letter: c.letter, text: shuffledTexts[i]}));
    // Answer doesn't need remapping since letters stay the same
    return q;
  }

  function startQuiz(count) {
    selectedQuestions = shuffleArray(ngfwSocQuestions.map(q => q)).slice(0, count).map(q => shuffleChoices(q));
    currentQuestion = 0; userAnswers = {}; showAnswerState = {};
    document.getElementById('total-points').textContent = count * POINTS_PER_Q;
    document.querySelectorAll('#home-page, #quiz-page, #results-page, #answer-key-page')
      .forEach(el => el.classList.toggle('hidden', el.id !== 'quiz-page'));
    displayQuestion();
  }

  function displayQuestion() {
    const q = selectedQuestions[currentQuestion];
    const total = selectedQuestions.length;
    document.getElementById('q-number').textContent = currentQuestion + 1;
    document.getElementById('q-total').textContent = `of ${total} questions`;
    document.getElementById('q-text').innerHTML = q.text.replace(/\n/g, '<br>');
    document.getElementById('q-type').textContent = q.type === 'multi' ? 'Choose all that apply' : 'Single Select';
    document.getElementById('q-type').className = 'question-type ' + q.type;
    document.getElementById('progress-fill').style.width = `${(currentQuestion / total) * 100}%`;

    const saved = userAnswers[currentQuestion] || [];
    document.getElementById('options-container').innerHTML = q.choices.map(c =>
      `<div class="option${saved.includes(c.letter) ? ' selected' : ''}" onclick="selectOption('${c.letter}')">
         <span class="option-letter">${c.letter}</span>
         <span class="option-label">${c.text}</span>
         <input type="${q.type === 'multi' ? 'checkbox' : 'radio'}" name="answer" value="${c.letter}" ${saved.includes(c.letter) ? 'checked' : ''}>
       </div>`
    ).join('');

    document.getElementById('btn-prev').disabled = currentQuestion === 0;
    document.getElementById('btn-next').style.display = currentQuestion < total - 1 ? 'inline-block' : 'none';
    document.getElementById('btn-submit').style.display = currentQuestion === total - 1 ? 'inline-block' : 'none';
    updateAnswerDisplay();
  }

  function selectOption(letter) {
    const q = selectedQuestions[currentQuestion];
    if (!userAnswers[currentQuestion]) userAnswers[currentQuestion] = [];
    if (q.type === 'single') { userAnswers[currentQuestion] = [letter]; }
    else {
      const idx = userAnswers[currentQuestion].indexOf(letter);
      idx >= 0 ? userAnswers[currentQuestion].splice(idx, 1) : userAnswers[currentQuestion].push(letter);
      userAnswers[currentQuestion].sort();
    }
    displayQuestion();
  }

  function toggleAnswer() { showAnswerState[currentQuestion] = !showAnswerState[currentQuestion]; updateAnswerDisplay(); }

  function updateAnswerDisplay() {
    const q = selectedQuestions[currentQuestion];
    const el = document.getElementById('answer-display');
    if (showAnswerState[currentQuestion]) {
      el.textContent = `✓ Correct Answer: ${q.answer}`;
      el.className = 'answer-display show';
    } else el.className = 'answer-display';
  }



  function nextQuestion() { if (currentQuestion < selectedQuestions.length - 1) { currentQuestion++; displayQuestion(); } }
  function prevQuestion() { if (currentQuestion > 0) { currentQuestion--; displayQuestion(); } }

  function submitQuiz() {
    const total = selectedQuestions.length;
    let correct = 0;
    for (let i = 0; i < total; i++) {
      if (((userAnswers[i] || []).sort().join('')) === selectedQuestions[i].answer) correct++;
    }
    const pct = Math.round((correct / total) * 100);
    const passed = pct >= PASS_PERCENT;
    document.getElementById('final-score').textContent = pct + '%';
    document.getElementById('final-score').className = 'results-score ' + (passed ? 'pass' : 'fail');
    document.getElementById('result-message').textContent = passed ? '🎉 PASSED! Congratulations!' : '❌ FAILED. Try Again!';
    document.getElementById('result-total').textContent = total;
    document.getElementById('result-correct').textContent = correct;
    document.getElementById('result-score').textContent = `${correct * POINTS_PER_Q} / ${total * POINTS_PER_Q} (${pct}%)`;
    document.getElementById('result-status').textContent = passed ? 'PASSED ✓' : 'FAILED ✗';
    document.getElementById('result-status').style.color = passed ? '#2e7d32' : '#c62828';

    let html = '';
    for (let i = 0; i < total; i++) {
      const ua = (userAnswers[i] || []).sort().join('');
      const ca = selectedQuestions[i].answer;
      const isCorrect = ua === ca;
      html += `<div class="review-item ${isCorrect ? 'correct' : 'incorrect'}">
        <div class="review-title">Q${i + 1}: ${isCorrect ? '✓ Correct' : '✗ Incorrect'}</div>
        <div class="review-answer"><strong>Your Answer:</strong> ${ua || 'Not answered'}</div>
        <div class="review-answer"><strong>Correct Answer:</strong> ${ca}</div>
      </div>`;
    }
    document.getElementById('review-list').innerHTML = html;
    document.getElementById('quiz-page').classList.add('hidden');
    document.getElementById('results-page').classList.remove('hidden');
  }

  function retakeQuiz() { startQuiz(selectedQuestions.length); }

  function goHome() {
    document.querySelectorAll('#home-page, #quiz-page, #results-page, #answer-key-page')
      .forEach(el => el.classList.toggle('hidden', el.id !== 'home-page'));
  }

  function showAnswerKey() {
    const all = ngfwSocQuestions.map(q => q);
    let html = '';
    for (let i = 0; i < all.length; i++) {
      const q = all[i];
      const correctSet = new Set(q.answer.split(''));
      html += `<div class="q-block"><div class="q-title">Q${i + 1} · ${q.type === 'multi' ? 'Choose all that apply' : 'Single Select'}</div>`;
      html += `<div class="q-text">${q.text.replace(/\n/g, '<br>')}</div>`;
      q.choices.forEach(c => {
        html += `<div class="ak-choice${correctSet.has(c.letter) ? ' correct' : ''}"><span class="letter-badge">${c.letter}</span><span>${c.text}</span></div>`;
      });
      html += `<div class="ak-answer">✅ Correct Answer: ${q.answer}</div></div>`;
    }
    document.getElementById('answer-key-content').innerHTML = html;
    document.querySelectorAll('#home-page, #quiz-page, #results-page, #answer-key-page')
      .forEach(el => el.classList.toggle('hidden', el.id !== 'answer-key-page'));
  }
</script>

</body>
</html>
