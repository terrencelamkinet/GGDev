<script>
// ===== SUB-PAGE SYSTEM =====
function openSubpage(id) {
  var sp = document.getElementById(id);
  if (!sp) { console.log('Sub-page not found:', id); return; }
  sp.classList.add('active');
  document.body.style.overflow = 'hidden';
}

function closeSubpage() {
  var active = document.querySelector('.subpage.active');
  if (active) {
    active.classList.remove('active');
    document.body.style.overflow = '';
  }
}



// Close subpage on back button (not on nav tab clicks)
document.addEventListener('click', function(e) {
  var target = e.target.closest('[onclick*="switchTab"]');
  if (!target && e.target.closest('.subpage-back')) {
    e.preventDefault();
    closeSubpage();
  }
});

// ===== VEHICLE MAINTENANCE =====
function refreshMaintData() {
  var list = document.getElementById('spMaintList');
  if (!list) return;
  list.innerHTML = '<div class="sp-row"><span class="sp-icon">🔄</span><span class="sp-value">Refreshing...</span></div>';
  
  // Fetch from Notion proxy or static data
  fetch('gg-maintenance.json?_=' + Date.now())
    .then(function(r) { return r.json(); })
    .then(function(data) {
      list.innerHTML = '';
      if (!data || !data.items || data.items.length === 0) {
        list.innerHTML = '<div class="sp-row"><span class="sp-icon">📭</span><span class="sp-value">No maintenance records</span></div>';
        return;
      }
      var now = new Date();
      data.items.forEach(function(item) {
        var due = item.nextService || '';
        var isUrgent = due && due.indexOf('overdue') >= 0;
        var dotColor = isUrgent ? 'red' : (due ? 'yellow' : 'gray');
        var row = document.createElement('div');
        row.className = 'sp-row';
        row.innerHTML = '<span class="sp-dot ' + dotColor + '" style="width:8px;height:8px;border-radius:50%;flex-shrink:0"></span>'
          + '<span class="sp-label" style="min-width:60px">' + escHtml(item.component) + '</span>'
          + '<span class="sp-value">' + escHtml(item.service || '') + '</span>'
          + '<span class="sp-badge" style="background:' + (isUrgent ? 'var(--danger-bg)' : 'var(--accent-light)') + ';color:' + (isUrgent ? 'var(--danger)' : 'var(--accent)') + '">' + escHtml(due) + '</span>';
        list.appendChild(row);
      });
    })
    .catch(function(e) {
      list.innerHTML = '<div class="sp-row"><span class="sp-icon">⚠️</span><span class="sp-value">Failed to load: ' + e.message + '</span></div>';
    });
}

// Auto-refresh maintenance data when vehicle page opens
document.addEventListener('click', function(e) {
  var card = e.target.closest('.clickable');
  if (card && card.getAttribute('onclick') && card.getAttribute('onclick').includes('sub-pers-vehicle')) {
    setTimeout(refreshMaintData, 300);
  }
});
</script>

</body>
