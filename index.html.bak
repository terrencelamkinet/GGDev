<!DOCTYPE html>
<html lang="zh-HK">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🦾</text></svg>">
  <title>GG Dashboard</title>
  <link rel="stylesheet" href="styles.css">
  <style>
    /* Password Lock Screen */
    #lockScreen {
      position: fixed;
      top: 0; left: 0; right: 0; bottom: 0;
      background: var(--bg);
      z-index: 9999;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-direction: column;
      transition: none;
    }
    #lockScreen.hidden {
      display: none;
    }
    .lock-box {
      background: var(--card-bg);
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 32px 28px;
      width: 300px;
      max-width: 85vw;
      text-align: center;
    }
    .lock-box .lock-icon { font-size: 48px; margin-bottom: 12px; }
    .lock-box h2 { margin: 0 0 6px; font-size: 18px; color: var(--text); }
    .lock-box p { margin: 0 0 20px; font-size: 13px; color: var(--text-dim); }
    .lock-box input {
      width: 100%;
      box-sizing: border-box;
      padding: 12px 14px;
      border-radius: 10px;
      border: 1px solid var(--border);
      background: var(--bg);
      color: var(--text);
      font-size: 16px;
      text-align: center;
      outline: none;
    }
    .lock-box input:focus { border-color: var(--accent); }
    .lock-box .lock-error {
      margin: 8px 0 0;
      font-size: 12px;
      color: var(--danger);
      opacity: 0;
      transition: opacity 0.2s;
    }
    .lock-box .lock-error.show { opacity: 1; }
    .lock-box button {
      margin-top: 16px;
      padding: 10px 0;
      width: 100%;
      border: none;
      border-radius: 10px;
      background: var(--accent);
      color: #fff;
      font-size: 15px;
      font-weight: 600;
      cursor: pointer;
    }
    .lock-box button:active { opacity: 0.8; }
  </style>
</head>
<body>

<!-- Lock Screen -->
<div id="lockScreen">
  <div class="lock-box">
    <div class="lock-icon">🦾</div>
    <h2>GG Dashboard</h2>
    <p>Enter password to access</p>
    <input type="password" id="passwordInput" placeholder="Password" autofocus
           onkeydown="if(event.key==='Enter') tryUnlock()">
    <p class="lock-error" id="lockError">❌ Wrong password</p>
    <button onclick="tryUnlock()">Unlock</button>
  </div>
</div>

<script>
// Password protection
const PASSWORD_HASH = '104428d9ef1269c9fdc99cbfefcc9d9da6105771437b50a1890ab23df0393f85';

async function sha256(msg) {
  const enc = new TextEncoder().encode(msg);
  const buf = await crypto.subtle.digest('SHA-256', enc);
  return Array.from(new Uint8Array(buf)).map(b => b.toString(16).padStart(2,'0')).join('');
}

async function tryUnlock() {
  const input = document.getElementById('passwordInput');
  const error = document.getElementById('lockError');
  const hash = await sha256(input.value);
  if (hash === PASSWORD_HASH) {
    sessionStorage.setItem('gg_unlocked', '1');
    document.getElementById('lockScreen').classList.add('hidden');
  } else {
    error.classList.add('show');
    input.value = '';
    input.focus();
  }
}

// On load, check localStorage
// Auto-refresh data every 60s (no page reload)
setInterval(function() {
  fetchData();
  fetchMemoryStats();
}, 60000);

window.addEventListener('DOMContentLoaded', function() {
  if (sessionStorage.getItem('gg_unlocked') !== '1') {
    document.getElementById('passwordInput').focus();
  } else {
    document.getElementById('lockScreen').classList.add('hidden');
  }
});
</script>

<div class="container">

  <!-- HEADER -->
