<script>
// Tab switching (after lock screen script)
function switchTab(event, tabId) {
  if (event) event.preventDefault();
  // Hide all pages
  document.querySelectorAll('.tab-page').forEach(p => p.classList.remove('active'));
  // Show target page
  document.getElementById(tabId).classList.add('active');
  // Update nav active state
  document.querySelectorAll('.bottom-nav .nav-tab').forEach(t => t.classList.remove('active'));
  event.currentTarget.classList.add('active');
  // Reset all subpages when switching tabs
  closeSubpage();
}

// Live timestamp for GG Mind
function updateGGTimestamp() {
  const el = document.getElementById('ggTimestamp');
  if (el) {
    const now = new Date();
    const hk = new Date(now.toLocaleString('en-US', {timeZone:'Asia/Hong_Kong'}));
    el.textContent = '🕐 ' + hk.toLocaleTimeString('zh-HK', {hour:'2-digit',minute:'2-digit'}) + ' HKT';
  }
}
updateGGTimestamp();
setInterval(updateGGTimestamp, 30000);

// ===== DATA FETCH =====
async function fetchData() {
  try {
    const r = await fetch('gg-data.json?_=' + Date.now());
    const d = await r.json();
    
    // Timestamp
    document.getElementById('dataTs').textContent = d.ts;
    document.getElementById('lastCheck').textContent = d.ts + ' HKT';
    document.getElementById('lastUpdateTime').textContent = '🕐 ' + d.ts;
    document.getElementById('sysLastUpdate').textContent = d.ts + ' HKT';
    
    // Status row
    setVal('valCpu', d.system.temp + '%');
    setVal('valMem', d.system.memory + '%', d.system.memory > 80 ? 'var(--danger)' : d.system.memory > 60 ? 'var(--warning)' : 'var(--accent)');
    setVal('valDisk', d.system.disk + '%', d.system.disk > 90 ? 'var(--danger)' : d.system.disk > 80 ? 'var(--warning)' : 'var(--accent)');
    setVal('valRem', d.reminders.total);
    setVal('valErrors', d.reminders.errors);
    
    // Services
    setDot('dotReminder', d.system.services['gg-reminder']);
    document.getElementById('detailReminder').textContent = d.reminders.total + ' reminders · ' + d.reminders.overdue + ' overdue';
    
    // Activity log
    var log = document.getElementById('activityLog');
    log.innerHTML = '';
    (d.activity || []).forEach(function(a) {
      var div = document.createElement('div');
      div.className = 'log-line';
      div.innerHTML = '<span class="log-time">' + a.time + '</span><span class="log-text">' + escHtml(a.text) + '</span>';
      log.appendChild(div);
    });
    
    // System badge status
    var allGreen = Object.values(d.system.services).every(function(s) { return s === 'green'; });
    var hasYellow = Object.values(d.system.services).some(function(s) { return s === 'yellow'; });
    var badge = document.getElementById('sysBadge');
    if (allGreen) {
      badge.className = 'status-badge green';
      badge.textContent = '● All OK';
    } else if (hasYellow) {
      badge.className = 'status-badge yellow';
      badge.textContent = '● Warning';
    } else {
      badge.className = 'status-badge red';
      badge.textContent = '● Issues';
    }
    var badge = document.getElementById('sysBadge');
    if (allGreen) {
      badge.className = 'status-badge green';
      badge.textContent = '● All OK';
    } else if (hasYellow) {
      badge.className = 'status-badge yellow';
      badge.textContent = '● Warning';
    } else {
      badge.className = 'status-badge red';
      badge.textContent = '● Issues';
    }
  } catch(e) {
    console.log('Data fetch failed, showing defaults:', e);
  }

  // Fetch memory stats
  setTimeout(fetchMemoryStats, 100);
}

function manualRefresh() {
  var btn = document.getElementById('refreshBtn') || document.querySelector('.refresh-btn');
  if (btn) { btn.classList.add('spinning'); }
  fetchData();
  fetchMemoryStats();
  refreshMaintData();
  setTimeout(function() {
    if (btn) { btn.classList.remove('spinning'); }
  }, 800);
}

async function fetchMemoryStats() {
  try {
    const r = await fetch('gg-memory-stats.json?_=' + Date.now());
    const d = await r.json();
    if (d.error) { console.log('Memory stats error:', d.error); return; }

    // Stats card on GG tab
    document.getElementById('memTotal').textContent = d.total.facts + ' 📝';
    var todayCount = 0;
    if (d.growth && d.growth.length > 0) {
      var last = d.growth[d.growth.length - 1];
      todayCount = last.added;
      var daysSince = new Date() - new Date(d.growth[0].date + 'T00:00:00+08:00');
      daysSince = Math.floor(daysSince / 86400000);
      document.getElementById('memTodayGrowth').textContent = '+' + todayCount;
      document.getElementById('memGrowthDays').textContent = daysSince + 'd';
      document.getElementById('memGrowthDot').className = todayCount > 20 ? 'dot green' : todayCount > 0 ? 'dot yellow' : 'dot gray';
    }
    var score8 = d.score_distribution['>=8'] || 0;
    document.getElementById('memScore8').textContent = score8 + ' 🏆';

    // Stats subpage
    if (document.getElementById('statsTotalCard')) {
      document.getElementById('statsTotalCard').querySelector('.sp-stat-val').textContent = d.total.facts;
      document.getElementById('statsTodayCard').querySelector('.sp-stat-val').textContent = '+' + todayCount;
      document.getElementById('statsTopCard').querySelector('.sp-stat-val').textContent = score8;
      var firstDate = d.growth.length > 0 ? d.growth[0].date : '-';
      document.getElementById('statsDaysCard').querySelector('.sp-stat-val').textContent = firstDate;
    }

    // Growth list
    var growthEl = document.getElementById('memGrowthList');
    if (growthEl && d.growth) {
      growthEl.innerHTML = '<table style="width:100%;font-size:13px;border-collapse:collapse">' +
        '<tr style="color:var(--text-dim);border-bottom:1px solid #333"><td style="padding:4px">Date</td><td style="padding:4px;text-align:right">+Added</td><td style="padding:4px;text-align:right">Total</td></tr>' +
        d.growth.slice().reverse().map(function(g) {
          var isToday = g.date === d.growth[d.growth.length-1].date;
          return '<tr style="' + (isToday ? 'color:var(--accent);font-weight:bold' : '') + ';border-bottom:1px solid #222">' +
            '<td style="padding:4px">' + g.date + '</td>' +
            '<td style="padding:4px;text-align:right;color:var(--success)">+' + g.added + '</td>' +
            '<td style="padding:4px;text-align:right">' + g.total + '</td></tr>';
        }).join('') + '</table>';
    }

    // Score distribution
    var distEl = document.getElementById('memScoreDist');
    if (distEl) {
      var labels = ['>=8','7-7.9','6-6.9','5-5.9','4-4.9','3-3.9','2-2.9','1-1.9','<1'];
      var colors = ['#f44336','#e57373','#ff9800','#ffb74d','#ffd54f','#81c784','#4caf50','#388e3c','#ddd'];
      distEl.innerHTML = '<table style="width:100%;font-size:13px;border-collapse:collapse">' +
        '<tr style="color:var(--text-dim);border-bottom:1px solid #333"><td style="padding:4px">Range</td><td style="padding:4px;text-align:right">Count</td><td style="padding:4px">Bar</td></tr>' +
        labels.map(function(l) {
          var cnt = d.score_distribution[l] || 0;
          var pct = Math.min(100, (cnt / 30) * 100);
          return '<tr style="border-bottom:1px solid #222">' +
            '<td style="padding:4px;color:var(--text-dim)">' + l + '</td>' +
            '<td style="padding:4px;text-align:right">' + cnt + '</td>' +
            '<td style="padding:4px"><div style="background:' + colors[labels.indexOf(l)] + ';width:' + pct + '%;height:14px;border-radius:3px;min-width:' + (cnt > 0 ? '4px' : '0') + '"></div></td></tr>';
        }).join('') + '</table>';
    }

    // Top 100 list
    var topEl = document.getElementById('memTop100List');
    if (topEl && d.top100) {
      topEl.innerHTML = d.top100.map(function(m, i) {
        var bg = m.importance >= 8 ? 'rgba(244,67,54,0.1)' : m.importance >= 6 ? 'rgba(255,152,0,0.08)' : 'transparent';
        return '<div class="sp-row" style="background:' + bg + ';padding:6px 0;border-bottom:1px solid #1a1a1a">' +
          '<span class="sp-dot" style="width:24px;flex-shrink:0;color:var(--text-dim);font-size:11px">#' + (i+1) + '</span>' +
          '<span class="sp-value" style="font-size:12px;line-height:1.4;flex:1">' + escHtml(m.doc.slice(0,100)) + '</span>' +
          '<span class="sp-badge" style="background:' + (m.importance >= 6 ? 'var(--warning-bg)' : 'var(--accent-light)') + ';color:' + (m.importance >= 6 ? 'var(--warning)' : 'var(--accent)') + ';flex-shrink:0;font-size:10px">' + m.importance.toFixed(1) + '</span></div>';
      }).join('');
    }
  } catch(e) {
    console.log('Memory stats fetch failed:', e);
  }
}
    // Fallback: show placeholder values so page isn't blank
    setVal('valCpu', '--');
    setVal('valMem', '--');
    setVal('valDisk', '--');
    setVal('valRem', '?');
    setVal('valErrors', '?');
    document.getElementById('dataTs').textContent = 'Offline';
    document.getElementById('lastCheck').textContent = 'Data unavailable';
    document.getElementById('detailReminder').textContent = 'Waiting for data...';
    var badge = document.getElementById('sysBadge');
    badge.className = 'status-badge gray';
    badge.textContent = '● Offline';
  }
}

function setVal(id, val, color) {
  var el = document.getElementById(id);
  if (el) { el.textContent = val; if (color) el.style.color = color; }
}
function setDot(id, status) {
  var el = document.getElementById(id);
  if (el) { el.className = 'dot ' + (status || 'gray'); }
}
function escHtml(s) {
  if (!s) return '';
  return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

// Set date & hourly refresh
(function(){
  var now = new Date();
  var opts = {weekday:'short', year:'numeric', month:'short', day:'numeric', timeZone:'Asia/Hong_Kong'};
  var el = document.getElementById('todayDate');
  if (el) el.textContent = now.toLocaleDateString('en-US', opts);
})();

fetchData();
setInterval(fetchData, 60000); // Every 1 min

// Placeholder actions
function openBriefing() {
  alert('🌅 Morning Briefing — (Backend integration pending)');
}
function runSystemCheck() {
  alert('🔍 System Check — see dashboard data');
}
</script>




