{
  "name": "kongger-api",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "db:init": "psql $PG_CONNECTION_STRING -f sql/01_schema.sql -f sql/02_indexes_triggers.sql -f sql/03_rls.sql",
    "db:seed": "psql $PG_CONNECTION_STRING -f sql/04_seed.sql"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.12.0"
  }
}
