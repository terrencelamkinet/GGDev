# ═══════════════════════════════════════════
# KONGGER API — Environment Configuration
# ═══════════════════════════════════════════
# Copy this file to .env and fill in your values.
# All values are read at startup via dotenv.
#
# This is a SELLABLE PRODUCT — all configurable
# values are listed here for white-label / rebrand.

# ── PostgreSQL ───────────────────────────────
# Required. Format: postgresql://user:password@host:port/database
# For production, use a strong, unique password.
PG_CONNECTION_STRING=postgresql://user:password@localhost:5432/kongger

# ── Authentication ───────────────────────────
# Required. At least 32 characters. Change for each deployment.
JWT_SECRET=change_this_to_a_random_64_char_string_minimum

# ── Server ───────────────────────────────────
# The port the API server listens on.
PORT=3001

# ── CORS ─────────────────────────────────────
# Allowed origins for CORS. Comma-separated for multiple.
# In development: *
# In production: https://your-frontend-domain.com
ALLOWED_ORIGIN=*

# ── Rate Limiting ────────────────────────────
# Max requests per minute (read vs write)
# RATE_LIMIT_READ=120
# RATE_LIMIT_WRITE=30
