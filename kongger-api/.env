# ═══════════════════════════════════════════
# KONGGER API — Environment Configuration
# ═══════════════════════════════════════════
# Copy this file as .env and fill in values.
# ALL values are read at startup via dotenv.

# ── PostgreSQL ───────────────────────────────
# Format: postgresql://user:password@host:port/database
PG_CONNECTION_STRING=postgresql://kongger_user:kongger_dev_pass@127.0.0.1:5432/kongger_db

# ── Authentication ───────────────────────────
# At least 32 chars. Change for production.
JWT_SECRET=kongger_jwt_secret_2026_kinet_poc_32chars_min

# ── Server ───────────────────────────────────
PORT=3001

# ── CORS ─────────────────────────────────────
# Comma-separated origins allowed to call the API.
# Use '*' for development. For production: https://kongger.example.com
ALLOWED_ORIGIN=*
