# ═══════════════════════════════════════════
# KONGGER WEB — Frontend Configuration
# ═══════════════════════════════════════════
# Set these as window.__KONGGER_CONFIG in index.html
# or via your deployment environment.

# API Base URL (where kongger-api is deployed)
# Example: https://api.kongger.example.com/api/v1
VITE_API_BASE=/api/v1

# Application name (for white-label / rebranding)
VITE_APP_NAME=Kongger

# Default theme colour
VITE_THEME_COLOUR=#4a90d9
